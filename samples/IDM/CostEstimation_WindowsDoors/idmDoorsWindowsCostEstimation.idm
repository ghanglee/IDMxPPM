{
  "version": "2.0.0",
  "appName": "IDMxPPM - Neo Seoul",
  "bpmnXml": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<definitions xmlns=\"http://www.omg.org/spec/BPMN/20100524/MODEL\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\" xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\" xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\" id=\"Definitions_1\" targetNamespace=\"http://example.org/bpmn/openings-cost\">\n  <collaboration id=\"Collaboration_1\">\n    <participant id=\"Participant_Architect\" name=\"Architect\" processRef=\"Process_Architect\" />\n    <participant id=\"Participant_CostEstimator\" name=\"Cost Estimator\" processRef=\"Process_CostEstimator\" />\n    <messageFlow id=\"MF_Arch_Cost\" sourceRef=\"Task_SendDesign\" targetRef=\"Task_ExtractQTO\" />\n    <messageFlow id=\"MF_Cost_Arch\" sourceRef=\"Task_PerformCostEstimation\" targetRef=\"Task_ReviewCostEstimation\" />\n  </collaboration>\n  <process id=\"Process_Architect\" isExecutable=\"false\">\n    <startEvent id=\"Start_Architect\" name=\"Start\">\n      <outgoing>SF_Start_Design</outgoing>\n    </startEvent>\n    <task id=\"Task_DesignBuilding\" name=\"Design a building\">\n      <incoming>SF_Start_Design</incoming>\n      <incoming>SF_No_Loop</incoming>\n      <outgoing>SF_Design_Specify</outgoing>\n    </task>\n    <task id=\"Task_SpecifyOpenings\" name=\"Specify window and door requirements\">\n      <incoming>SF_Design_Specify</incoming>\n      <outgoing>SF_Specify_Send</outgoing>\n      <dataOutputAssociation id=\"DOA_WinProps\">\n        <targetRef>DataObjectReference_WindowProperties</targetRef>\n      </dataOutputAssociation>\n      <dataOutputAssociation id=\"DOA_DoorProps\">\n        <targetRef>DataObjectReference_DoorProperties</targetRef>\n      </dataOutputAssociation>\n    </task>\n    <task id=\"Task_SendDesign\" name=\"Send the design to the cost estimator\">\n      <incoming>SF_Specify_Send</incoming>\n    </task>\n    <task id=\"Task_ReviewCostEstimation\" name=\"Review the combined cost estimation\">\n      <outgoing>SF_Review_Gateway</outgoing>\n      <property id=\"Prop_Review_Win\" name=\"__targetRef_placeholder\" />\n      <dataInputAssociation id=\"DIA_ReviewWinCost\">\n        <sourceRef>DataObjectReference_WindowCostEstimate</sourceRef>\n        <targetRef>Prop_Review_Win</targetRef>\n      </dataInputAssociation>\n      <property id=\"Prop_Review_Door\" name=\"__targetRef_placeholder\" />\n      <dataInputAssociation id=\"DIA_ReviewDoorCost\">\n        <sourceRef>DataObjectReference_DoorCostEstimate</sourceRef>\n        <targetRef>Prop_Review_Door</targetRef>\n      </dataInputAssociation>\n    </task>\n    <exclusiveGateway id=\"GW_BudgetCheck\" name=\"Is the combined cost below the budget?\">\n      <incoming>SF_Review_Gateway</incoming>\n      <outgoing>SF_Yes_End</outgoing>\n      <outgoing>SF_No_Loop</outgoing>\n    </exclusiveGateway>\n    <endEvent id=\"End_Architect\" name=\"End\">\n      <incoming>SF_Yes_End</incoming>\n    </endEvent>\n    <sequenceFlow id=\"SF_Start_Design\" sourceRef=\"Start_Architect\" targetRef=\"Task_DesignBuilding\" />\n    <sequenceFlow id=\"SF_Design_Specify\" sourceRef=\"Task_DesignBuilding\" targetRef=\"Task_SpecifyOpenings\" />\n    <sequenceFlow id=\"SF_Specify_Send\" sourceRef=\"Task_SpecifyOpenings\" targetRef=\"Task_SendDesign\" />\n    <sequenceFlow id=\"SF_Review_Gateway\" sourceRef=\"Task_ReviewCostEstimation\" targetRef=\"GW_BudgetCheck\" />\n    <sequenceFlow id=\"SF_Yes_End\" name=\"Yes\" sourceRef=\"GW_BudgetCheck\" targetRef=\"End_Architect\">\n      <conditionExpression xsi:type=\"tFormalExpression\">Yes</conditionExpression>\n    </sequenceFlow>\n    <sequenceFlow id=\"SF_No_Loop\" name=\"No — revise design\" sourceRef=\"GW_BudgetCheck\" targetRef=\"Task_DesignBuilding\">\n      <conditionExpression xsi:type=\"tFormalExpression\">No</conditionExpression>\n    </sequenceFlow>\n    <dataObjectReference id=\"DataObjectReference_WindowProperties\" name=\"er_WindowProperties\" dataObjectRef=\"DataObject_WindowProperties\" />\n    <dataObject id=\"DataObject_WindowProperties\" />\n    <dataObjectReference id=\"DataObjectReference_DoorProperties\" name=\"er_DoorProperties\" dataObjectRef=\"DataObject_DoorProperties\" />\n    <dataObject id=\"DataObject_DoorProperties\" />\n    <dataObjectReference id=\"DataObjectReference_WindowCostEstimate\" name=\"er_WindowCostEstimate\" dataObjectRef=\"DataObject_WindowCostEstimate\" />\n    <dataObject id=\"DataObject_WindowCostEstimate\" />\n    <dataObjectReference id=\"DataObjectReference_DoorCostEstimate\" name=\"er_DoorCostEstimate\" dataObjectRef=\"DataObject_DoorCostEstimate\" />\n    <dataObject id=\"DataObject_DoorCostEstimate\" />\n  </process>\n  <process id=\"Process_CostEstimator\" isExecutable=\"false\">\n    <task id=\"Task_ExtractQTO\" name=\"Extract window and door quantity takeoffs\">\n      <outgoing>SF_Extract_Perform</outgoing>\n      <property id=\"Prop_Extract_Win\" name=\"__targetRef_placeholder\" />\n      <dataInputAssociation id=\"DIA_ExtractWinBIM\">\n        <sourceRef>DataObjectReference_WindowProperties</sourceRef>\n        <targetRef>Prop_Extract_Win</targetRef>\n      </dataInputAssociation>\n      <property id=\"Prop_Extract_Door\" name=\"__targetRef_placeholder\" />\n      <dataInputAssociation id=\"DIA_ExtractDoorBIM\">\n        <sourceRef>DataObjectReference_DoorProperties</sourceRef>\n        <targetRef>Prop_Extract_Door</targetRef>\n      </dataInputAssociation>\n      <dataOutputAssociation id=\"DOA_WinQTO\">\n        <targetRef>DataObjectReference_WindowQTO</targetRef>\n      </dataOutputAssociation>\n      <dataOutputAssociation id=\"DOA_DoorQTO\">\n        <targetRef>DataObjectReference_DoorQTO</targetRef>\n      </dataOutputAssociation>\n    </task>\n    <task id=\"Task_PerformCostEstimation\" name=\"Perform the combined cost estimation\">\n      <incoming>SF_Extract_Perform</incoming>\n      <property id=\"Prop_Cost_Win\" name=\"__targetRef_placeholder\" />\n      <dataInputAssociation id=\"DIA_PerformWinQTO\">\n        <sourceRef>DataObjectReference_WindowQTO</sourceRef>\n        <targetRef>Prop_Cost_Win</targetRef>\n      </dataInputAssociation>\n      <property id=\"Prop_Cost_Door\" name=\"__targetRef_placeholder\" />\n      <dataInputAssociation id=\"DIA_PerformDoorQTO\">\n        <sourceRef>DataObjectReference_DoorQTO</sourceRef>\n        <targetRef>Prop_Cost_Door</targetRef>\n      </dataInputAssociation>\n      <dataOutputAssociation id=\"DOA_WinCostEst\">\n        <targetRef>DataObjectReference_WindowCostEstimate</targetRef>\n      </dataOutputAssociation>\n      <dataOutputAssociation id=\"DOA_DoorCostEst\">\n        <targetRef>DataObjectReference_DoorCostEstimate</targetRef>\n      </dataOutputAssociation>\n    </task>\n    <sequenceFlow id=\"SF_Extract_Perform\" sourceRef=\"Task_ExtractQTO\" targetRef=\"Task_PerformCostEstimation\" />\n    <dataObjectReference id=\"DataObjectReference_WindowQTO\" name=\"er_WindowQuantities\" dataObjectRef=\"DataObject_WindowQTO\" />\n    <dataObject id=\"DataObject_WindowQTO\" />\n    <dataObjectReference id=\"DataObjectReference_DoorQTO\" name=\"er_DoorQuantities\" dataObjectRef=\"DataObject_DoorQTO\" />\n    <dataObject id=\"DataObject_DoorQTO\" />\n  </process>\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_1\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_1\" bpmnElement=\"Collaboration_1\">\n      <bpmndi:BPMNShape id=\"Shape_Participant_Architect\" bpmnElement=\"Participant_Architect\" isHorizontal=\"true\">\n        <dc:Bounds x=\"100\" y=\"40\" width=\"1500\" height=\"400\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_Start\" bpmnElement=\"Start_Architect\">\n        <dc:Bounds x=\"152\" y=\"202\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"149\" y=\"243\" width=\"42\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_DesignBuilding\" bpmnElement=\"Task_DesignBuilding\">\n        <dc:Bounds x=\"240\" y=\"180\" width=\"120\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_SpecifyOpenings\" bpmnElement=\"Task_SpecifyOpenings\">\n        <dc:Bounds x=\"420\" y=\"180\" width=\"155\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_SendDesign\" bpmnElement=\"Task_SendDesign\">\n        <dc:Bounds x=\"645\" y=\"180\" width=\"130\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_ReviewCost\" bpmnElement=\"Task_ReviewCostEstimation\">\n        <dc:Bounds x=\"885\" y=\"180\" width=\"160\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_Gateway\" bpmnElement=\"GW_BudgetCheck\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1120\" y=\"195\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1082\" y=\"251\" width=\"127\" height=\"40\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_End\" bpmnElement=\"End_Architect\">\n        <dc:Bounds x=\"1247\" y=\"202\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1245\" y=\"243\" width=\"40\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_WinProps\" bpmnElement=\"DataObjectReference_WindowProperties\">\n        <dc:Bounds x=\"450\" y=\"300\" width=\"36\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"420\" y=\"358\" width=\"96\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_DoorProps\" bpmnElement=\"DataObjectReference_DoorProperties\">\n        <dc:Bounds x=\"540\" y=\"300\" width=\"36\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"510\" y=\"358\" width=\"96\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_WinCostEst\" bpmnElement=\"DataObjectReference_WindowCostEstimate\">\n        <dc:Bounds x=\"912\" y=\"300\" width=\"36\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"878\" y=\"358\" width=\"104\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_DoorCostEst\" bpmnElement=\"DataObjectReference_DoorCostEstimate\">\n        <dc:Bounds x=\"1002\" y=\"300\" width=\"36\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"968\" y=\"358\" width=\"104\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNEdge id=\"Edge_SF_Start_Design\" bpmnElement=\"SF_Start_Design\">\n        <di:waypoint x=\"188\" y=\"220\" /><di:waypoint x=\"240\" y=\"220\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_SF_Design_Specify\" bpmnElement=\"SF_Design_Specify\">\n        <di:waypoint x=\"360\" y=\"220\" /><di:waypoint x=\"420\" y=\"220\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_SF_Specify_Send\" bpmnElement=\"SF_Specify_Send\">\n        <di:waypoint x=\"575\" y=\"220\" /><di:waypoint x=\"645\" y=\"220\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_SF_Review_Gateway\" bpmnElement=\"SF_Review_Gateway\">\n        <di:waypoint x=\"1045\" y=\"220\" /><di:waypoint x=\"1120\" y=\"220\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_SF_Yes_End\" bpmnElement=\"SF_Yes_End\">\n        <di:waypoint x=\"1170\" y=\"220\" /><di:waypoint x=\"1247\" y=\"220\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1199\" y=\"202\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_SF_No_Loop\" bpmnElement=\"SF_No_Loop\">\n        <di:waypoint x=\"1145\" y=\"195\" /><di:waypoint x=\"1145\" y=\"100\" /><di:waypoint x=\"300\" y=\"100\" /><di:waypoint x=\"300\" y=\"180\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"660\" y=\"66\" width=\"100\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DOA_WinProps\" bpmnElement=\"DOA_WinProps\">\n        <di:waypoint x=\"475\" y=\"260\" /><di:waypoint x=\"468\" y=\"300\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DOA_DoorProps\" bpmnElement=\"DOA_DoorProps\">\n        <di:waypoint x=\"525\" y=\"260\" /><di:waypoint x=\"558\" y=\"300\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DIA_ReviewWinCost\" bpmnElement=\"DIA_ReviewWinCost\">\n        <di:waypoint x=\"930\" y=\"300\" /><di:waypoint x=\"930\" y=\"260\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DIA_ReviewDoorCost\" bpmnElement=\"DIA_ReviewDoorCost\">\n        <di:waypoint x=\"1020\" y=\"300\" /><di:waypoint x=\"1020\" y=\"260\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNShape id=\"Shape_Participant_CostEstimator\" bpmnElement=\"Participant_CostEstimator\" isHorizontal=\"true\">\n        <dc:Bounds x=\"100\" y=\"560\" width=\"1500\" height=\"250\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_ExtractQTO\" bpmnElement=\"Task_ExtractQTO\">\n        <dc:Bounds x=\"645\" y=\"590\" width=\"160\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_PerformCost\" bpmnElement=\"Task_PerformCostEstimation\">\n        <dc:Bounds x=\"885\" y=\"590\" width=\"170\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_WinQTO\" bpmnElement=\"DataObjectReference_WindowQTO\">\n        <dc:Bounds x=\"668\" y=\"700\" width=\"36\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"638\" y=\"758\" width=\"96\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_DoorQTO\" bpmnElement=\"DataObjectReference_DoorQTO\">\n        <dc:Bounds x=\"758\" y=\"700\" width=\"36\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"728\" y=\"758\" width=\"96\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNEdge id=\"Edge_SF_Extract_Perform\" bpmnElement=\"SF_Extract_Perform\">\n        <di:waypoint x=\"805\" y=\"630\" /><di:waypoint x=\"885\" y=\"630\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DOA_WinQTO\" bpmnElement=\"DOA_WinQTO\">\n        <di:waypoint x=\"700\" y=\"670\" /><di:waypoint x=\"686\" y=\"700\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DOA_DoorQTO\" bpmnElement=\"DOA_DoorQTO\">\n        <di:waypoint x=\"750\" y=\"670\" /><di:waypoint x=\"776\" y=\"700\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DIA_PerformWinQTO\" bpmnElement=\"DIA_PerformWinQTO\">\n        <di:waypoint x=\"704\" y=\"725\" /><di:waypoint x=\"885\" y=\"625\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DIA_PerformDoorQTO\" bpmnElement=\"DIA_PerformDoorQTO\">\n        <di:waypoint x=\"794\" y=\"725\" /><di:waypoint x=\"885\" y=\"640\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DOA_WinCostEst\" bpmnElement=\"DOA_WinCostEst\">\n        <di:waypoint x=\"930\" y=\"590\" /><di:waypoint x=\"930\" y=\"350\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DOA_DoorCostEst\" bpmnElement=\"DOA_DoorCostEst\">\n        <di:waypoint x=\"1020\" y=\"590\" /><di:waypoint x=\"1020\" y=\"350\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DIA_ExtractWinBIM\" bpmnElement=\"DIA_ExtractWinBIM\">\n        <di:waypoint x=\"468\" y=\"350\" /><di:waypoint x=\"468\" y=\"630\" /><di:waypoint x=\"645\" y=\"630\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DIA_ExtractDoorBIM\" bpmnElement=\"DIA_ExtractDoorBIM\">\n        <di:waypoint x=\"558\" y=\"350\" /><di:waypoint x=\"558\" y=\"640\" /><di:waypoint x=\"645\" y=\"640\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"MF_Arch_Cost_di\" bpmnElement=\"MF_Arch_Cost\">\n        <di:waypoint x=\"710\" y=\"260\" /><di:waypoint x=\"725\" y=\"590\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"MF_Cost_Arch_di\" bpmnElement=\"MF_Cost_Arch\">\n        <di:waypoint x=\"970\" y=\"590\" /><di:waypoint x=\"970\" y=\"440\" /><di:waypoint x=\"965\" y=\"440\" /><di:waypoint x=\"965\" y=\"260\" />\n      </bpmndi:BPMNEdge>\n    </bpmndi:BPMNPlane>\n  </bpmndi:BPMNDiagram>\n</definitions>\n",
  "headerData": {
    "title": "Information Delivery Manual for Cost Estimation of Doors and Windows",
    "shortTitle": "OpeningsCostIDM",
    "subTitle": "An integrated IDM for window and door cost estimation in building projects",
    "authors": [
      {
        "type": "person",
        "id": "author-1",
