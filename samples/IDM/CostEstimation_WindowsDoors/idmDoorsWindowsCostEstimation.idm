    ],
    "organization": "",
    "version": "1.0",
    "creationDate": "",
    "status": "WD",
    "localDocumentStatus": "",
    "localCode": "",
    "language": "EN",
    "projectStages": ["design", "production"],
    "projectStagesIso": ["design", "production"],
    "projectStagesAia": [],
    "projectStagesRiba": [],
    "useCategories": ["Estimate Cost", "Quantify Windows", "Quantify Doors"],
    "uses": [
      { "verb": "Estimate", "noun": "Cost" },
      { "verb": "Quantify", "noun": "Windows" },
      { "verb": "Quantify", "noun": "Doors" }
    ],
    "useClassification": null,
    "region": "international",
    "regions": ["international"],
    "summary": "This IDM specifies the information required to support the combined cost estimation of windows and doors in building projects. It integrates the Exchange Requirements from the IDM for Cost Estimation of Windows and the IDM for Cost Estimation of Doors into a single specification, enabling architects and cost estimators to exchange all necessary opening-related data in one coordinated process. The IDM covers geometric properties, material and hardware specifications, quantity take-offs, and cost data for both element types, supporting accurate budget preparation and procurement planning during the design and production stages.",
    "revisionHistory": [
      {
        "date": "2026-05-22",
        "description": "Initial creation — combining WindowCostIDM and DoorCostIDM"
      }
    ],
    "changeLogs": [
      {
        "id": "log-1",
        "changeDateTime": "2026-05-22T00:00:00",
        "changeSummary": "Initial creation — combining WindowCostIDM and DoorCostIDM",
        "changedBy": "author-1",
        "changes": []
      }
    ],
    "contributors": [],
    "copyright": "Copyright 2026 Building Informatics Group (BIG), Yonsei University",
    "keywords": ["cost estimation", "windows", "doors", "openings", "BIM", "quantity takeoff"],
    "relatedStandards": [],
    "externalReferences": [],
    "objectives": "The aim of this IDM is to define the minimum information that must be exchanged between design authoring tools (e.g., architectural BIM software) and cost estimation tools when performing cost estimation for both windows and doors in a building project. By combining the two opening types in a single IDM, this specification enables a coordinated cost estimation workflow in which the architect provides specifications for all openings in a single handover, and the cost estimator processes them together. The scope covers all window types in building envelopes and all door types in building envelopes and interior partitions. Structural opening works (lintels, reveals, cills) and specialist glazing systems are outside the scope.",
    "aimAndScope": "The aim of this IDM is to define the minimum information that must be exchanged between design authoring tools (e.g., architectural BIM software) and cost estimation tools when performing cost estimation for both windows and doors in a building project. By combining the two opening types in a single IDM, this specification enables a coordinated cost estimation workflow in which the architect provides specifications for all openings in a single handover, and the cost estimator processes them together. The scope covers all window types in building envelopes and all door types in building envelopes and interior partitions. Structural opening works (lintels, reveals, cills) and specialist glazing systems are outside the scope.",
    "benefits": "Enables a single coordinated BIM handover from architect to cost estimator covering all opening elements. Reduces duplication of effort compared to running window and door cost estimation as separate processes. Supports early cost feedback during the design phase for the full opening budget. Provides a structured basis for procurement planning, hardware scheduling, and glazing specifications in one document. Fire-rated openings (both doors and windows) can be systematically identified and priced.",
    "limitations": "This IDM does not cover specialist glazing systems requiring bespoke structural engineering (e.g., structural glass fins, electrochromic glass) or automated door systems requiring specialist mechanical engineering. Costs for structural opening works, wall reveals, sub-sills, and lintels are outside the scope. Regional price variations must be accounted for separately. The IDM assumes a single cost estimator handles both element types; where doors and windows are estimated by separate subcontractors, the individual IDMs (WindowCostIDM, DoorCostIDM) should be used instead.",
    "actors": "",
