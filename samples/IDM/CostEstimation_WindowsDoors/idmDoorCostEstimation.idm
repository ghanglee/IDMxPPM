{
  "version": "2.0.0",
  "appName": "IDMxPPM - Neo Seoul",
  "bpmnXml": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<definitions xmlns=\"http://www.omg.org/spec/BPMN/20100524/MODEL\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\" xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\" xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\" id=\"Definitions_1\" targetNamespace=\"http://example.org/bpmn/door-cost\">\n  <collaboration id=\"Collaboration_1\">\n    <participant id=\"Participant_Architect\" name=\"Architect\" processRef=\"Process_Architect\" />\n    <participant id=\"Participant_CostEstimator\" name=\"Cost Estimator\" processRef=\"Process_CostEstimator\" />\n    <messageFlow id=\"Flow_Arch_Cost\" sourceRef=\"Task_SendDesign\" targetRef=\"Task_ExtractQTO\" />\n    <messageFlow id=\"Flow_Cost_Arch\" sourceRef=\"Task_PerformCostEstimation\" targetRef=\"Task_ReviewCostEstimation\" />\n  </collaboration>\n  <process id=\"Process_Architect\" isExecutable=\"false\">\n    <startEvent id=\"Start_Architect\" name=\"Start\">\n      <outgoing>SF_Start_Design</outgoing>\n    </startEvent>\n    <task id=\"Task_DesignBuilding\" name=\"Design a building\">\n      <incoming>SF_Start_Design</incoming>\n      <incoming>SF_No_Loop</incoming>\n      <outgoing>SF_Design_Specify</outgoing>\n    </task>\n    <task id=\"Task_SpecifyDoors\" name=\"Specify door requirements\">\n      <incoming>SF_Design_Specify</incoming>\n      <outgoing>SF_Specify_Send</outgoing>\n      <dataOutputAssociation id=\"DOA_DoorProperties\">\n        <targetRef>DataObjectReference_DoorProperties</targetRef>\n      </dataOutputAssociation>\n    </task>\n    <task id=\"Task_SendDesign\" name=\"Send the design to the cost estimator\">\n      <incoming>SF_Specify_Send</incoming>\n    </task>\n    <task id=\"Task_ReviewCostEstimation\" name=\"Review the door cost estimation\">\n      <outgoing>SF_Review_Gateway</outgoing>\n      <property id=\"Property_ReviewInput\" name=\"__targetRef_placeholder\" />\n      <dataInputAssociation id=\"DIA_ReviewCost\">\n        <sourceRef>DataObjectReference_DoorCostEstimate</sourceRef>\n        <targetRef>Property_ReviewInput</targetRef>\n      </dataInputAssociation>\n    </task>\n    <exclusiveGateway id=\"GW_BudgetCheck\" name=\"Is the door cost below the budget?\">\n      <incoming>SF_Review_Gateway</incoming>\n      <outgoing>SF_Yes_End</outgoing>\n      <outgoing>SF_No_Loop</outgoing>\n    </exclusiveGateway>\n    <endEvent id=\"End_Architect\" name=\"End\">\n      <incoming>SF_Yes_End</incoming>\n    </endEvent>\n    <sequenceFlow id=\"SF_Start_Design\" sourceRef=\"Start_Architect\" targetRef=\"Task_DesignBuilding\" />\n    <sequenceFlow id=\"SF_Design_Specify\" sourceRef=\"Task_DesignBuilding\" targetRef=\"Task_SpecifyDoors\" />\n    <sequenceFlow id=\"SF_Specify_Send\" sourceRef=\"Task_SpecifyDoors\" targetRef=\"Task_SendDesign\" />\n    <sequenceFlow id=\"SF_Review_Gateway\" sourceRef=\"Task_ReviewCostEstimation\" targetRef=\"GW_BudgetCheck\" />\n    <sequenceFlow id=\"SF_Yes_End\" name=\"Yes\" sourceRef=\"GW_BudgetCheck\" targetRef=\"End_Architect\">\n      <conditionExpression xsi:type=\"tFormalExpression\">Yes</conditionExpression>\n    </sequenceFlow>\n    <sequenceFlow id=\"SF_No_Loop\" name=\"No — revise door design\" sourceRef=\"GW_BudgetCheck\" targetRef=\"Task_DesignBuilding\">\n      <conditionExpression xsi:type=\"tFormalExpression\">No</conditionExpression>\n    </sequenceFlow>\n    <dataObjectReference id=\"DataObjectReference_DoorProperties\" name=\"er_DoorProperties\" dataObjectRef=\"DataObject_DoorProperties\" />\n    <dataObject id=\"DataObject_DoorProperties\" />\n  </process>\n  <process id=\"Process_CostEstimator\" isExecutable=\"false\">\n    <task id=\"Task_ExtractQTO\" name=\"Extract door quantity takeoffs\">\n      <outgoing>SF_Extract_Perform</outgoing>\n      <property id=\"Property_ExtractInput\" name=\"__targetRef_placeholder\" />\n      <dataInputAssociation id=\"DIA_ExtractBIM\">\n        <sourceRef>DataObjectReference_DoorProperties</sourceRef>\n        <targetRef>Property_ExtractInput</targetRef>\n      </dataInputAssociation>\n      <dataOutputAssociation id=\"DOA_QTO\">\n        <targetRef>DataObjectReference_DoorQTO</targetRef>\n      </dataOutputAssociation>\n    </task>\n    <task id=\"Task_PerformCostEstimation\" name=\"Perform the door cost estimation\">\n      <incoming>SF_Extract_Perform</incoming>\n      <property id=\"Property_CostInput\" name=\"__targetRef_placeholder\" />\n      <dataInputAssociation id=\"DIA_PerformQTO\">\n        <sourceRef>DataObjectReference_DoorQTO</sourceRef>\n        <targetRef>Property_CostInput</targetRef>\n      </dataInputAssociation>\n      <dataOutputAssociation id=\"DOA_CostEstimate\">\n        <targetRef>DataObjectReference_DoorCostEstimate</targetRef>\n      </dataOutputAssociation>\n    </task>\n    <sequenceFlow id=\"SF_Extract_Perform\" sourceRef=\"Task_ExtractQTO\" targetRef=\"Task_PerformCostEstimation\" />\n    <dataObjectReference id=\"DataObjectReference_DoorCostEstimate\" name=\"er_DoorCostInformation\" dataObjectRef=\"DataObject_DoorCostEstimate\" />\n    <dataObject id=\"DataObject_DoorCostEstimate\" />\n    <dataObjectReference id=\"DataObjectReference_DoorQTO\" name=\"er_DoorQuantities\" dataObjectRef=\"DataObject_DoorQTO\" />\n    <dataObject id=\"DataObject_DoorQTO\" />\n  </process>\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_1\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_1\" bpmnElement=\"Collaboration_1\">\n      <bpmndi:BPMNShape id=\"Shape_Participant_Architect\" bpmnElement=\"Participant_Architect\" isHorizontal=\"true\">\n        <dc:Bounds x=\"100\" y=\"40\" width=\"1160\" height=\"286\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_Start\" bpmnElement=\"Start_Architect\">\n        <dc:Bounds x=\"152\" y=\"147\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"149\" y=\"188\" width=\"42\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_DesignBuilding\" bpmnElement=\"Task_DesignBuilding\">\n        <dc:Bounds x=\"240\" y=\"125\" width=\"110\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_SpecifyDoors\" bpmnElement=\"Task_SpecifyDoors\">\n        <dc:Bounds x=\"400\" y=\"125\" width=\"120\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_SendDesign\" bpmnElement=\"Task_SendDesign\">\n        <dc:Bounds x=\"572\" y=\"125\" width=\"120\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_ReviewCost\" bpmnElement=\"Task_ReviewCostEstimation\">\n        <dc:Bounds x=\"840\" y=\"125\" width=\"150\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_Gateway\" bpmnElement=\"GW_BudgetCheck\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"1050\" y=\"140\" width=\"50\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1022\" y=\"196\" width=\"108\" height=\"40\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_End\" bpmnElement=\"End_Architect\">\n        <dc:Bounds x=\"1162\" y=\"147\" width=\"36\" height=\"36\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1160\" y=\"188\" width=\"40\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_DoorProperties\" bpmnElement=\"DataObjectReference_DoorProperties\">\n        <dc:Bounds x=\"447\" y=\"237\" width=\"36\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"430\" y=\"296\" width=\"89\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNEdge id=\"Edge_SF_Start_Design\" bpmnElement=\"SF_Start_Design\">\n        <di:waypoint x=\"188\" y=\"165\" /><di:waypoint x=\"240\" y=\"165\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_SF_Design_Specify\" bpmnElement=\"SF_Design_Specify\">\n        <di:waypoint x=\"350\" y=\"165\" /><di:waypoint x=\"400\" y=\"165\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_SF_Specify_Send\" bpmnElement=\"SF_Specify_Send\">\n        <di:waypoint x=\"520\" y=\"165\" /><di:waypoint x=\"572\" y=\"165\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_SF_Review_Gateway\" bpmnElement=\"SF_Review_Gateway\">\n        <di:waypoint x=\"990\" y=\"165\" /><di:waypoint x=\"1050\" y=\"165\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_SF_Yes_End\" bpmnElement=\"SF_Yes_End\">\n        <di:waypoint x=\"1100\" y=\"165\" /><di:waypoint x=\"1162\" y=\"165\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1122\" y=\"147\" width=\"18\" height=\"14\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_SF_No_Loop\" bpmnElement=\"SF_No_Loop\">\n        <di:waypoint x=\"1075\" y=\"140\" /><di:waypoint x=\"1075\" y=\"90\" /><di:waypoint x=\"295\" y=\"90\" /><di:waypoint x=\"295\" y=\"125\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"654\" y=\"56\" width=\"73\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNShape id=\"Shape_Participant_CostEstimator\" bpmnElement=\"Participant_CostEstimator\" isHorizontal=\"true\">\n        <dc:Bounds x=\"100\" y=\"440\" width=\"1160\" height=\"200\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_ExtractQTO\" bpmnElement=\"Task_ExtractQTO\">\n        <dc:Bounds x=\"572\" y=\"470\" width=\"150\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_PerformCost\" bpmnElement=\"Task_PerformCostEstimation\">\n        <dc:Bounds x=\"840\" y=\"470\" width=\"150\" height=\"80\" />\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_DoorCostEstimate\" bpmnElement=\"DataObjectReference_DoorCostEstimate\">\n        <dc:Bounds x=\"1032\" y=\"485\" width=\"36\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"1006\" y=\"547\" width=\"87\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Shape_DoorQTO\" bpmnElement=\"DataObjectReference_DoorQTO\">\n        <dc:Bounds x=\"772\" y=\"535\" width=\"36\" height=\"50\" />\n        <bpmndi:BPMNLabel><dc:Bounds x=\"747\" y=\"596\" width=\"88\" height=\"27\" /></bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNEdge id=\"Edge_SF_Extract_Perform\" bpmnElement=\"SF_Extract_Perform\">\n        <di:waypoint x=\"722\" y=\"510\" /><di:waypoint x=\"840\" y=\"510\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DOA_DoorProperties\" bpmnElement=\"DOA_DoorProperties\">\n        <di:waypoint x=\"460\" y=\"205\" /><di:waypoint x=\"460\" y=\"237\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DIA_ReviewCost\" bpmnElement=\"DIA_ReviewCost\">\n        <di:waypoint x=\"1048\" y=\"485\" /><di:waypoint x=\"932\" y=\"205\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DIA_ExtractBIM\" bpmnElement=\"DIA_ExtractBIM\">\n        <di:waypoint x=\"460\" y=\"287\" /><di:waypoint x=\"460\" y=\"510\" /><di:waypoint x=\"572\" y=\"510\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DOA_QTO\" bpmnElement=\"DOA_QTO\">\n        <di:waypoint x=\"722\" y=\"536\" /><di:waypoint x=\"772\" y=\"554\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DIA_PerformQTO\" bpmnElement=\"DIA_PerformQTO\">\n        <di:waypoint x=\"808\" y=\"553\" /><di:waypoint x=\"840\" y=\"540\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Edge_DOA_CostEstimate\" bpmnElement=\"DOA_CostEstimate\">\n        <di:waypoint x=\"990\" y=\"510\" /><di:waypoint x=\"1032\" y=\"510\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_Arch_Cost_di\" bpmnElement=\"Flow_Arch_Cost\">\n        <di:waypoint x=\"632\" y=\"205\" /><di:waypoint x=\"632\" y=\"470\" />\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_Cost_Arch_di\" bpmnElement=\"Flow_Cost_Arch\">\n        <di:waypoint x=\"915\" y=\"470\" /><di:waypoint x=\"915\" y=\"205\" />\n      </bpmndi:BPMNEdge>\n    </bpmndi:BPMNPlane>\n  </bpmndi:BPMNDiagram>\n</definitions>\n",
