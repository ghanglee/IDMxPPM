{"version":"2.0.0","format":"idm-binary","appName":"IDMxPPM - Neo Seoul","bpmnXml":"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\" xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\" xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\" xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\" xmlns:xppm=\"http://xppm.org/schema/1.0/bpmn\" xmlns:kdim=\"http://www.buildingsmart.or.kr/kidm\" id=\"ibo-4dfca2fd-6a1e-4ca1-808e-0006df9c8361\" targetNamespace=\"http://www.omg.org/spec/BPMN/20100524/MODEL\" exporter=\"KBim BPMN\" exporterVersion=\"1.0\">\n  <bpmn:globalTask id=\"ibo-8914d910-35d9-4e49-b3f6-faee98d2b5df\" name=\"Nachtrag prüfen\" />\n  <bpmn:globalTask id=\"ibo-0bfceac7-f7af-4142-8cc7-365711a39fb5\" name=\"Begründung formulieren\" />\n  <bpmn:globalTask id=\"ibo-c366eedd-d089-4deb-ba21-7cc28caedf69\" name=\"Nachtrag beauftragen\" />\n  <bpmn:process id=\"ibo-84c383b1-93ca-40cf-95d9-3fe062f420e5\" processType=\"None\" isClosed=\"false\" isExecutable=\"false\">\n    <bpmn:dataObjectReference id=\"ibo-0ef31399-efaa-4f01-a75f-7cc6bdc749b5\" name=\"Nachtragsmeldung UN\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_c35e3ef1-545a-4c0e-9288-bede03dd04c0\">Grundlage für die Meldung eines Nachtrags vom Unternehmer.</bpmn:documentation>\n      <bpmn:extensionElements>\n        <xppm:Property name=\"link\" />\n      </bpmn:extensionElements>\n    </bpmn:dataObjectReference>\n    <bpmn:dataObjectReference id=\"ibo-3fff4c88-565c-4e5b-bde0-9f6631ea451a\" name=\"Begründung Ablehnung TBA\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_c5d8827b-2612-4d9a-add0-cd2f29e33d49\">Begründung der Ablehnung des Nachtrags zu Händen des Unternehmers.</bpmn:documentation>\n      <bpmn:extensionElements>\n        <xppm:Property name=\"link\" />\n      </bpmn:extensionElements>\n    </bpmn:dataObjectReference>\n    <bpmn:dataObjectReference id=\"ibo-939300a9-1a9f-4d96-8739-191b49ef5aa9\" name=\"Beauftragung TBA\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_290ec442-a383-4b2a-9d62-f18bf1d5d798\">Beauftragung des Unternehmers mit den Hinweisen zum Umfang.</bpmn:documentation>\n      <bpmn:extensionElements>\n        <xppm:Property name=\"link\" />\n      </bpmn:extensionElements>\n    </bpmn:dataObjectReference>\n  </bpmn:process>\n  <bpmn:process id=\"ibo-ac5b4869-348f-4bb7-ab48-a63485deec7b\" processType=\"None\" isClosed=\"false\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"ibo-b056ce29-616b-403d-9f70-c594c26276a7\">\n      <bpmn:lane id=\"ibo-0f6c00ef-04b5-4b57-ab49-1692857afcee\" name=\"GPL INFRA Projekte\">\n        <bpmn:flowNodeRef>ibo-5e06f3c2-eaf5-44d1-bf59-2ef8b72f1d48</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>ibo-3d6ad8ae-071a-412d-b83c-8c8fbe949c4b</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>ibo-0a4e2d95-452c-41b8-a824-6861de7c1599</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>ibo-b52d8a37-0d31-4b20-ac94-7738386e91a1</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>ibo-8e7f6b3a-7a0f-4ffa-b594-ef722aaad87c</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>ibo-94cd9fc3-5737-414b-a1c5-24d024dad58d</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"ibo-0684483e-1b22-4f7a-af09-db73a287b31f\" name=\"Kantonsingenieur\">\n        <bpmn:flowNodeRef>ibo-a15b3687-0da5-49c6-915a-ff356b4db563</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n    <bpmn:sequenceFlow id=\"ibo-45b29567-37f3-4d63-b85e-2e02927c77c2\" name=\"Nein\" sourceRef=\"ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35\" targetRef=\"ibo-b52d8a37-0d31-4b20-ac94-7738386e91a1\">\n      <bpmn:extensionElements>\n        <xppm:Property name=\"link\" />\n      </bpmn:extensionElements>\n    </bpmn:sequenceFlow>\n    <bpmn:sequenceFlow id=\"ibo-c4633114-157e-4bd1-a90b-bdcd4ebfefa3\" sourceRef=\"ibo-a15b3687-0da5-49c6-915a-ff356b4db563\" targetRef=\"ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35