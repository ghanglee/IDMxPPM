-b594-ef722aaad87c\" name=\"Nachtrag beauftragen\" startQuantity=\"0\" completionQuantity=\"0\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_2afa2a1f-5431-4976-8a82-26b78b5883e9\">Der GPL formuliert die Beauftragung an den Unternehmer.</bpmn:documentation>\n      <bpmn:incoming>ibo-8e7f6b3a-7a0f-4ffa-b594-ef722aaad87c</bpmn:incoming>\n      <bpmn:outgoing>ibo-8e7f6b3a-7a0f-4ffa-b594-ef722aaad87c</bpmn:outgoing>\n      <bpmn:dataInputAssociation id=\"ibo-721e5c5a-8513-4456-8676-63be6b357832\">\n        <bpmn:sourceRef>ibo-153351dc-9bae-4c85-9b51-eeb411c5b9b6</bpmn:sourceRef>\n      </bpmn:dataInputAssociation>\n      <bpmn:dataOutputAssociation id=\"ibo-47aabde8-d964-40a4-96ea-907f53abfa37\">\n        <bpmn:targetRef>ibo-939300a9-1a9f-4d96-8739-191b49ef5aa9</bpmn:targetRef>\n      </bpmn:dataOutputAssociation>\n    </bpmn:task>\n    <bpmn:exclusiveGateway id=\"ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35\" gatewayDirection=\"Diverging\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_d5c7c5e6-8758-44cd-8ecd-799af724d6c5\">Wird der Nachtrag freigegeben?</bpmn:documentation>\n      <bpmn:incoming>ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35</bpmn:incoming>\n      <bpmn:outgoing>ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35</bpmn:outgoing>\n      <bpmn:outgoing>ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n    <bpmn:task id=\"ibo-a15b3687-0da5-49c6-915a-ff356b4db563\" name=\"Nachtrag prüfen\" startQuantity=\"0\" completionQuantity=\"0\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_f311279a-7bc0-41b6-a082-432e5a83f4f8\">Die vom GPL angereicherte Information wird vom Kantonsingenieur geprüft.</bpmn:documentation>\n      <bpmn:incoming>ibo-a15b3687-0da5-49c6-915a-ff356b4db563</bpmn:incoming>\n      <bpmn:outgoing>ibo-a15b3687-0da5-49c6-915a-ff356b4db563</bpmn:outgoing>\n      <bpmn:dataInputAssociation id=\"ibo-82cdee12-f5ac-447b-a2a8-6ddd7f7adce4\">\n        <bpmn:sourceRef>ibo-e715b79c-f6c5-4c92-988a-01401ea4ba20</bpmn:sourceRef>\n      </bpmn:dataInputAssociation>\n      <bpmn:dataOutputAssociation id=\"ibo-273ca4bb-308d-420d-ba4a-3fe9eff19029\">\n        <bpmn:targetRef>ibo-153351dc-9bae-4c85-9b51-eeb411c5b9b6</bpmn:targetRef>\n      </bpmn:dataOutputAssociation>\n    </bpmn:task>\n    <bpmn:task id=\"ibo-b52d8a37-0d31-4b20-ac94-7738386e91a1\" name=\"Begründung formulieren\" startQuantity=\"0\" completionQuantity=\"0\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_c4c09200-7129-46f7-a3a2-bd275fb0af24\">Der GPL formuliert die Begründung für die Ablehnung.</bpmn:documentation>\n      <bpmn:incoming>ibo-b52d8a37-0d31-4b20-ac94-7738386e91a1</bpmn:incoming>\n      <bpmn:incoming>ibo-b52d8a37-0d31-4b20-ac94-7738386e91a1</bpmn:incoming>\n      <bpmn:dataOutputAssociation id=\"ibo-75402b95-821f-4070-b066-9f8f1479309f\">\n        <bpmn:targetRef>ibo-3fff4c88-565c-4e5b-bde0-9f6631ea451a</bpmn:targetRef>\n      </bpmn:dataOutputAssociation>\n    </bpmn:task>\n    <bpmn:exclusiveGateway id=\"ibo-0a4e2d95-452c-41b8-a824-6861de7c1599\" gatewayDirection=\"Diverging\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_6b3ee045-8b51-40e9-8d63-ad0a20001935\">Wird der Nachtrag weitergeleitet?</bpmn:documentation>\n      <bpmn:incoming>ibo-0a4e2d95-452c-41b8-a824-6861de7c1599</bpmn:incoming>\n      <bpmn:outgoing>ibo-0a4e2d95-452c-41b8-a824-6861de7c1599</bpmn:outgoing>\n      <bpmn:outgoing>ibo-0a4e2d95-452c-41b8-a824-6861de7c1599</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n    <bpmn:task id=\"ibo-3d6ad8ae-071a-412d-b83c-8c8fbe949c4b\" name=\"Nachtrag prüfen\" startQuantity=\"0\" completionQuantity=\"0\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_a9248df4-25b5-42b2-bc35-c31dfbe48251\">Die Informationen des Unternehmers werden vom GPL geprüft (Plausibilität/Berechtigung/Grössenrelation zur Leistung) und entweder dem KI empfohlen zur Freigabe, oder dem an den Unternehmerzurückgewiesen. </bpmn:documentation>\n      <bpmn:incoming>ibo-3d6ad8ae-071a-412d-b83c-8c8fbe949c4b</bpmn:incoming>\n      <bpmn:outgoing>ibo-3d6ad8ae-071a-412d-b83c-8c8fbe949c4b</bpmn:outgoing>\n      <bpmn:dataInputAssociation id=\"ibo-fbb8f722-025c-42d6-a166-b727069c4629\">\n        <bpmn:sourceRef>ibo-0ef31399-efaa-4f01-a75f-7cc6bdc749b5</bpmn:sourceRef>\n      </bpmn:dataInputAssociation>\n      <bpmn:dataOutputAssociation id=\"ibo-5d34e011-e4d7-4158-a904-c6b5cd501461\">\n        <bpmn:targetRef>ibo-e715b79c-f6c5-4c92-988a-01401ea4ba20</bpmn:targetRef>\n      </bpmn:dataOutputAssociation>\n    </bpmn:task>\n    <bpmn:startEvent id=\"ibo-5e06f3c2-eaf5-44d1-bf59-2ef8b72f1d48\" name=\"Start \">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_6632b59b-e8a7-49c9-bbc8-bc97fe3b80d5\">Bedarf an einen Nachtrag wird vom Unternehmer gemeldet.</bpmn:documentation>\n      <bpmn:extensionElements>\n        <xppm:Property name=\"link\" />\n      </bpmn:extensionElements>\n      <bpmn:outgoing>ibo-5e06f3c2-eaf5-44d1-bf59-2ef8b72f1d48</bpmn:outgoing>\n    </bpmn:startEvent>\n    <bpmn:endEvent id=\"ibo-94cd9fc3-5737-414b-a1c5-24d024dad58d\" name=\"Ende \">\n      <bpmn:incoming>ibo-94cd9fc3-5737-414b-a1c5-24d024dad58d</bpmn:incoming>\n    </bpmn:endEvent>\n    <bpmn:sequenceFlow id=\"ibo-08e61091-8497-4dcf-a2cf-a79ffd876285\" sourceRef=\"ibo-8e7f6b3a-7a0f-4ffa-b594-ef722aaad87c\" targetRef=\"ibo-94cd9fc3-5737-414b-a1c5-24d024dad58d\" />\n  </bpmn:process>\n  <bpmn:collaboration id=\"ibo-bf6fc00d-9acd-42cf-b33d-e5fcf3a1e06a\" isClosed=\"false\">\n    <bpmn:participant id=\"ibo-593f7409-5777-437f-b915-7105b4987f28\" name=\"05_RE_525 Nachtragsmeldung\" />\n    <bpmn:participant id=\"ibo-2001c948-866d-4554-bbeb-7d45300f25bc\" name=\"Unternehmer\" processRef=\"ibo-84c383b1-93ca-40cf-95d9-3fe062f420e5\" />\n    <bpmn:participant id=\"ibo-df82b2a0-5cf5-4b1d-b1b1-930badb3169a\" name=\"TBA\" processRef=\"ibo-ac5b4869-348f-4bb7-ab48-a63485deec7b\" />\n    <bpmn:messageFlow id=\"ibo-b3c2c249-1ad5-4476-b870-049a12345af7\" sourceRef=\"ibo-2001c948-866d-4554-bbeb-7d45300f25bc