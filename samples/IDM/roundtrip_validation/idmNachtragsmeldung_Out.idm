technischen Akteuren ist (bisher) nicht berücksichtigt (SAP etc.).","language":"DE","use":"Phase 5 Realisierung Teilphase 5.3 Ausführung","actorsList":[{"id":"actor-ibo-2001c948-866d-4554-bbeb-7d45300f25bc-1777719971717","name":"Unternehmer","role":"","actorType":"group","bpmnId":"ibo-2001c948-866d-4554-bbeb-7d45300f25bc","bpmnShapeName":"Unternehmer","subActors":[]},{"id":"actor-ibo-df82b2a0-5cf5-4b1d-b1b1-930badb3169a-1777719971717","name":"TBA","role":"","actorType":"group","bpmnId":"ibo-df82b2a0-5cf5-4b1d-b1b1-930badb3169a","bpmnShapeName":"TBA","subActors":[{"id":"subactor-ibo-0f6c00ef-04b5-4b57-ab49-1692857afcee-1777719971717","name":"GPL INFRA Projekte","role":"","bpmnShapeName":"ibo-0f6c00ef-04b5-4b57-ab49-1692857afcee"},{"id":"subactor-ibo-0684483e-1b22-4f7a-af09-db73a287b31f-1777719971717","name":"Kantonsingenieur","role":"","bpmnShapeName":"ibo-0684483e-1b22-4f7a-af09-db73a287b31f"}]}],"targetPhases":{"iso22263":["Production"],"aiaB101":[],"ribaPow":[]},"summaryFigures":[],"aimAndScopeFigures":[],"benefitsFigures":[],"limitationsFigures":[],"title":"Nachtragsmeldung","authors":[{"type":"person","givenName":"Kilian","familyName":"Reyer","uri":"kilian.reyer@bs.ch","affiliation":""},{"type":"person","givenName":"Mathieu","familyName":"Harnist","uri":"","affiliation":""},{"type":"person","givenName":"Christian","familyName":"Kränkl","uri":"","affiliation":""}],"uses":[{"verb":"Phase","noun":"5 Realisierung Teilphase 5.3 Ausführung"}],"projectStagesIso":["Production"],"projectStagesAia":[],"projectStagesRiba":[],"regions":["international"],"benefits":"","limitations":"","keywords":[],"references":"","additionalDescription":"","revisionHistory":[{"date":"2026-02-25","description":"Updated: idmCode, fullTitle, documentStatus, author"},{"date":"2026-02-25","description":"Updated: idmCode"},{"date":"2026-02-25","description":"Updated: fullTitle"},{"date":"2026-02-25","description":"Updated: shortTitle, idmCode, fullTitle"},{"date":"2026-02-25","description":"Updated: idmCode"}],"idmGuid":"fd3f8c8c-df82-4cbb-9651-a68c500c89e4","ucGuid":"e01eb799-3bb4-4ac0-99a2-ab0a4199dbbc"},"erHierarchy":[{"id":"987488c5-2b1b-4aaa-ad1c-57e969ceff81","name":"Grundlage","shortTitle":"er_Grundlage","idmCode":"er-Phase 5 Realisierung Teilphase 5.3 Ausführung-PD-PD--DE-Reyer-20260224-Grundlage-NP","localCode":"","status":"NP","version":"","description":"Der ER bildet die Grundlage/Basis/Root der Informationsanforderungen ab.","descriptionFigures":[],"informationUnits":[],"constraints":[],"subERs":[{"id":"ba84fd47-2092-494a-9fde-71220c0400ea","name":"Nachtragsmeldung UN","shortTitle":"er_NachtragsmeldungUn","description":"Der Unternehmer liefert seine Daten für den Nachtrag als Grundlage.","descriptionFigures":[],"informationUnits":[{"id":"5d6c9ebb-04a4-473f-974d-876998acee57","name":"Begründung","dataType":"String / Text","isMandatory":true,"definition":"Begründung/Gegenstand des Nachtrags. Nachvollziehbare und ausreichend ausführliche Begründung, warum dieser Nachtrag benötigt wird  inkl. Begründung, warum der Nachtragsinhalt nicht bereits mit dem Hauptauftrag beschafft werden konnte. Dafür sind Textbausteine vorgesehen. Diese müsse aber immer noch mit dem Inhalt respektive der Sachlage der jeweiligen Anmeldung ergänzt werden. Textbausteine siehe Mail Mathieu 19.02.2026, 11:41 Uhr.","definitionFigures":[],"examples":"1) Bestellungs- und Planungsänderungen\n2) Unvorhergesehene Verhältnisse und zusätzliche Anforderungen\n3) Mengenabweichungen\n4) Bauablauf- und terminbedingte Anpassungen","exampleImages":[],"correspondingExternalElements":[{"id":"575eb535-d8e0-4e57-8410-d18fd2496370","basis":"IFC 4x3 ADD2","name":"IfcProjectOrder.LongDescription","description":"IFC Attribute","uri":""}],"subInformationUnits":[]},{"id":"606b37c7-8beb-4e0a-898b-e752d7384ffe","name":"Begründung Dokumente","dataType":"Image Drawing","isMandatory":false,"definition":"Dateien, Dokumente (z.B. kostenschätzung) oder Bilder, die die Plausibilität und die Berechntigung des Nachtrags begründen.","definitionFigures":[],"examples":"","exampleImages":[],"correspondingExternalElements":[{"id":"9a109757-6679-480e-9999-ee7cc8eb64c9","basis":"IFC 4x3 ADD2","name":"IfcDocumentInformation","description":"IFC Entity","uri":""}],"subInformationUnits":[]},{"id":"416a0ed0-ddff-452d-8827-7a0570142cf5","name":"Nachtrag Nr.","dataType":"Numeric","isMandatory":true,"definition":"Nummer des Nachtrags. Bei 2 vorhandenen genehmigten Aufträgen wäre die Zahl 3 hier einzutragen.","definitionFigures":[],"examples":"","exampleImages":[],"correspondingExternalElements":[{"id":"c6b32d8d-36fa-4cbd-90ea-a6c6a24ebe8b","basis":"IFC 4x3 ADD2","name":"IfcProjectOrder.Identification","description":"IFC Attribute","uri":""}],"subInformationUnits":[]},{"id":"5996d870-68ef-4260-9213-958aa89c01c9","name":"Summe Nachtrag","dataType":"Numeric","isMandatory":true,"definition":"Höhe des Nachtrags [CHF] (Mehrleistung=positiver Betrag; Minderleistung=negativer Betrag).","definitionFigures":[],"examples":"","exampleImages":[],"correspondingExternalElements":[{"id":"8544a667-207c-4089-a666-34eec77404be","basis":"IFC 4x3 ADD2","name":"IfcCostValue.AppliedValue","description":"IFC Attribute","uri":""}],"subInformationUnits":[]}],"subERs":[],"constraints":[],"correspondingMvd":null},{"id":"bd254f36-b66e-46af-87b4-f489e6b0869f","name":"Nachtragsmeldung GPL TBA","shortTitle":"er_NachtragsmeldungGplTba","description":"","descriptionFigures":[],"informationUnits":[{"id":"4cd0e99a-0880-433b-a5a6-a72c9f124da1","name":"Projektindentifikation (aus dem SAP...)","dataType":"String / Text","isMandatory":true,"definition":"Angaben für die Identifikation des Projektes (Kapitelbezeichnung)","definitionFigures":[],"examples":"","exampleImages":[],"correspondingExternalElements":[{"id":"533a323f-71db-4fce-a7f5-ae986b147664","basis":"IFC 4x3 ADD2","name":"IfcProject.Identification","description":"IFC Attribute","uri":""}],"subInformationUnits":[{"id":"b4d7ec9d-a4a5-48a0-89e7-84448477a99b","name":"Pro