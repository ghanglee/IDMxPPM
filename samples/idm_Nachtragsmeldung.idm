  "erHierarchy": [
    {
      "id": "987488c5-2b1b-4aaa-ad1c-57e969ceff81",
      "guid": "987488c5-2b1b-4aaa-ad1c-57e969ceff81",
      "shortTitle": "er_Grundlage",
      "name": "Grundlage",
      "description": "Der ER bildet die Grundlage/Basis/Root der Informationsanforderungen ab.",
      "descriptionFigures": [],
      "informationUnits": [],
      "subERs": [
        {
          "id": "ba84fd47-2092-494a-9fde-71220c0400ea",
          "guid": "ba84fd47-2092-494a-9fde-71220c0400ea",
          "shortTitle": "er_NachtragsmeldungUn",
          "name": "Nachtragsmeldung UN",
          "description": "Der Unternehmer liefert seine Daten für den Nachtrag als Grundlage.",
          "descriptionFigures": [],
          "informationUnits": [
            {
              "id": "5d6c9ebb-04a4-473f-974d-876998acee57",
              "name": "Begründung",
              "dataType": "String",
              "isMandatory": true,
              "definition": "Begründung/Gegenstand des Nachtrags. Nachvollziehbare und ausreichend ausführliche Begründung, warum dieser Nachtrag benötigt wird inkl. Begründung, warum der Nachtragsinhalt nicht bereits mit dem Hauptauftrag beschafft werden konnte. Dafür sind Textbausteine vorgesehen. Diese müsse aber immer noch mit dem Inhalt respektive der Sachlage der jeweiligen Anmeldung ergänzt werden. Textbausteine siehe Mail Mathieu 19.02.2026, 11:41 Uhr.",
              "definitionFigures": [],
              "examples": "1) Bestellungs- und Planungsänderungen 2) Unvorhergesehene Verhältnisse und zusätzliche Anforderungen 3) Mengenabweichungen 4) Bauablauf- und terminbedingte Anpassungen",
              "exampleImages": [],
              "correspondingExternalElements": [],
              "subInformationUnits": []
            },
            {
              "id": "606b37c7-8beb-4e0a-898b-e752d7384ffe",
              "name": "Begründung Dokumente",
              "dataType": "Image Drawing",
              "isMandatory": false,
              "definition": "Dateien, Dokumente (z.B. kostenschätzung) oder Bilder, die die Plausibilität und die Berechntigung des Nachtrags begründen.",
              "definitionFigures": [],
              "examples": "",
              "exampleImages": [],
              "correspondingExternalElements": [],
              "subInformationUnits": []
            },
            {
              "id": "416a0ed0-ddff-452d-8827-7a0570142cf5",
              "name": "Nachtrag Nr.",
              "dataType": "Number",
              "isMandatory": true,
              "definition": "Nummer des Nachtrags. Bei 2 vorhandenen genehmigten Aufträgen wäre die Zahl 3 hier einzutragen.",
              "definitionFigures": [],
              "examples": "",
              "exampleImages": [],
              "correspondingExternalElements": [],
              "subInformationUnits": []
            },
            {
              "id": "5996d870-68ef-4260-9213-958aa89c01c9",
              "name": "Summe Nachtrag",
              "dataType": "Number",
              "isMandatory": true,
              "definition": "Höhe des Nachtrags [CHF] (Mehrleistung=positiver Betrag; Minderleistung=negativer Betrag).",
              "definitionFigures": [
                {
                  "id": "fig-1782735596603-119doug",
                  "name": "ER_Screenshot.png",
                  "caption": "",
                  "data": "data:image/png;base64,",
                  "type": "image/png"
                }
              ],
              "examples": "",
