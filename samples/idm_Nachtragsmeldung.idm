              "subInformationUnits": []
            },
            {
              "id": "374ee691-7ee1-49ff-a999-e46616aa96b1",
              "name": "SAP Nr. Grundvertrag",
              "dataType": "Number",
              "isMandatory": true,
              "definition": "Identifikation des Vertrags im SAP. 10-stellige Nummer.",
              "definitionFigures": [],
              "examples": "5110002826",
              "exampleImages": [
                {
                  "id": "img-1782735182251-b7w0l7",
                  "name": "Image\\Image(3).png",
                  "caption": "Image 1",
                  "type": "image/png",
                  "filePath": "Image\\Image(3).png"
                }
              ],
              "correspondingExternalElements": [],
              "subInformationUnits": []
            },
            {
              "id": "646d7beb-c436-461b-a447-eadbb4b8165c",
              "name": "Kontonummer",
              "dataType": "Number",
              "isMandatory": true,
              "definition": "Auf welche Kontonummer wird der Vertrag und der Nachtrag abgerechnet. Die nummer ist [12-stellig]-[4-stellig]-[1-stellig]",
              "definitionFigures": [],
              "examples": "617011021089-1000-6",
              "exampleImages": [
                {
                  "id": "img-1782735182251-8usx93",
                  "name": "Image\\Image(4).png",
                  "caption": "Image 1",
                  "type": "image/png",
                  "filePath": "Image\\Image(4).png"
                }
              ],
              "correspondingExternalElements": [],
              "subInformationUnits": []
            }
          ]
        },
        {
          "id": "94a637dc-3a2c-4d36-a9cf-2e1829f82c35",
          "name": "Zusammenfassung Entscheid",
          "dataType": "String",
          "isMandatory": true,
          "definition": "Kapitelbezeichnung",
          "definitionFigures": [],
          "examples": "",
          "exampleImages": [],
          "correspondingExternalElements": [],
          "subInformationUnits": [
            {
              "id": "357bd508-95f3-4ade-96b2-81512815db20",
              "name": "Nachtrag genehmigt",
              "dataType": "Boolean",
              "isMandatory": true,
              "definition": "Ist der Nachtrag genehmigt? Sind die Begründungen hinweichend plausibel und ist die Berechtigung ausserhalb des Grundvertrags gegeben? Bei \"Ja\" wird der Antrag an den Unternehmer weitergeleitet. Bei \"Nein\" erfolgt eine Benachrichtigung an den Gesamtprojektleiter, der die BEgründung verfasst (siehe ER_BegründungAblehnung).",
              "definitionFigures": [],
              "examples": "",
              "exampleImages": [],
              "correspondingExternalElements": [],
              "subInformationUnits": []
            },
            {
              "id": "0565d3a7-06ae-44ae-912a-106ba6368afe",
              "name": "Summe Nachtrag",
              "dataType": "Number",
              "isMandatory": true,
              "definition": "Höhe des Nachtrags [CHF] (Mehrleistung=positiver Betrag; Minderleistung=negativer Betrag).",
              "definitionFigures": [],
              "examples": "",
              "exampleImages": [],
              "correspondingExternalElements": [],
              "subInformationUnits": []
            },
            {
              "id": "7f5ea5d0-e5b9-4952-b54d-cde695add524",
              "name": "Nachtrag Nr.",
              "dataType": "Number",
              "isMandatory": true,
              "definition": "Nummer des Nachtrags. Bei 2 vorhandenen genehmigten Aufträgen wäre die Zahl 3 hier einzutragen.",
              "definitionFigures": [],
              "examples": "",
              "exampleImages": [],
              "correspondingExternalElements": [],
              "subInformationUnits": []
            },
            {
              "id": "88106489-7aa3-46b3-82c1-408204f066cb",
              "name": "Begründung Dokumente",
              "dataType": "Image Drawing",
              "isMandatory": false,
              "definition": "Dateien, Dokumente (z.B. kostenschätzung) oder Bilder, die die Plausibilität und die Berechntigung des Nachtrags begründen.",
              "definitionFigures": [],
              "examples": "",
              "exampleImages": [],
              "correspondingExternalElements": [],
              "subInformationUnits": []
            },
            {
              "id": "490338d3-c61a-4bf4-a1c1-6606ae979518",
              "name": "Begründung",
              "dataType": "String",
              "isMandatory": true,
              "definition": "Begründung/Gegenstand des Nachtrags. Nachvollziehbare und ausreichend ausführliche Begründung, warum dieser Nachtrag benötigt wird inkl. Begründung, warum der Nachtragsinhalt nicht bereits mit dem Hauptauftrag beschafft werden konnte. Dafür sind Textbausteine vorgesehen. Diese müsse aber immer noch mit dem Inhalt respektive der Sachlage der jeweiligen Anmeldung ergänzt werden. Textbausteine siehe Mail Mathieu 19.02.2026, 11:41 Uhr.",
              "definitionFigures": [],
              "examples": "1) Bestellungs- und Planungsänderungen 2) Unvorhergesehene Verhältnisse und zusätzliche Anforderungen 3) Mengenabweichungen 4) Bauablauf- und terminbedingte Anpassungen",
              "exampleImages": [],
              "correspondingExternalElements": [],
              "subInformationUnits": []
            }
          ]
        }
      ],
      "subERs": [],
