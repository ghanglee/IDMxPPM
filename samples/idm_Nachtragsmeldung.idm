  "bpmnXml": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\" xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\" xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\" xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\" xmlns:xppm=\"http://xppm.org/schema/1.0/bpmn\" xmlns:kdim=\"http://www.buildingsmart.or.kr/kidm\" id=\"ibo-4dfca2fd-6a1e-4ca1-808e-0006df9c8361\" targetNamespace=\"http://www.omg.org/spec/BPMN/20100524/MODEL\" exporter=\"KBim BPMN\" exporterVersion=\"1.0\">\n  <bpmn:globalTask id=\"ibo-8914d910-35d9-4e49-b3f6-faee98d2b5df\" name=\"Nachtrag prüfen\" />\n  <bpmn:globalTask id=\"ibo-0bfceac7-f7af-4142-8cc7-365711a39fb5\" name=\"Begründung formulieren\" />\n  <bpmn:globalTask id=\"ibo-c366eedd-d089-4deb-ba21-7cc28caedf69\" name=\"Nachtrag beauftragen\" />\n  <bpmn:process id=\"ibo-84c383b1-93ca-40cf-95d9-3fe062f420e5\" processType=\"None\" isClosed=\"false\" isExecutable=\"false\">\n    <bpmn:dataObjectReference id=\"ibo-0ef31399-efaa-4f01-a75f-7cc6bdc749b5\" name=\"Nachtragsmeldung UN\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_c35e3ef1-545a-4c0e-9288-bede03dd04c0\">Grundlage für die Meldung eines Nachtrags vom Unternehmer.</bpmn:documentation>\n      <bpmn:extensionElements>\n        <xppm:Property name=\"link\" />\n      </bpmn:extensionElements>\n    </bpmn:dataObjectReference>\n    <bpmn:dataObjectReference id=\"ibo-3fff4c88-565c-4e5b-bde0-9f6631ea451a\" name=\"Begründung Ablehnung TBA\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_c5d8827b-2612-4d9a-add0-cd2f29e33d49\">Begründung der Ablehnung des Nachtrags zu Händen des Unternehmers.</bpmn:documentation>\n      <bpmn:extensionElements>\n        <xppm:Property name=\"link\" />\n      </bpmn:extensionElements>\n    </bpmn:dataObjectReference>\n    <bpmn:dataObjectReference id=\"ibo-939300a9-1a9f-4d96-8739-191b49ef5aa9\" name=\"Beauftragung TBA\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_290ec442-a383-4b2a-9d62-f18bf1d5d798\">Beauftragung des Unternehmers mit den Hinweisen zum Umfang.</bpmn:documentation>\n      <bpmn:extensionElements>\n        <xppm:Property name=\"link\" />\n      </bpmn:extensionElements>\n    </bpmn:dataObjectReference>\n  </bpmn:process>\n  <bpmn:process id=\"ibo-ac5b4869-348f-4bb7-ab48-a63485deec7b\" processType=\"None\" isClosed=\"false\" isExecutable=\"false\">\n    <bpmn:laneSet id=\"ibo-b056ce29-616b-403d-9f70-c594c26276a7\">\n      <bpmn:lane id=\"ibo-0f6c00ef-04b5-4b57-ab49-1692857afcee\" name=\"GPL INFRA Projekte\">\n        <bpmn:flowNodeRef>ibo-5e06f3c2-eaf5-44d1-bf59-2ef8b72f1d48</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>ibo-3d6ad8ae-071a-412d-b83c-8c8fbe949c4b</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>ibo-0a4e2d95-452c-41b8-a824-6861de7c1599</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>ibo-b52d8a37-0d31-4b20-ac94-7738386e91a1</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>ibo-8e7f6b3a-7a0f-4ffa-b594-ef722aaad87c</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>ibo-94cd9fc3-5737-414b-a1c5-24d024dad58d</bpmn:flowNodeRef>\n      </bpmn:lane>\n      <bpmn:lane id=\"ibo-0684483e-1b22-4f7a-af09-db73a287b31f\" name=\"Kantonsingenieur\">\n        <bpmn:flowNodeRef>ibo-a15b3687-0da5-49c6-915a-ff356b4db563</bpmn:flowNodeRef>\n        <bpmn:flowNodeRef>ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35</bpmn:flowNodeRef>\n      </bpmn:lane>\n    </bpmn:laneSet>\n    <bpmn:sequenceFlow id=\"ibo-45b29567-37f3-4d63-b85e-2e02927c77c2\" name=\"Nein\" sourceRef=\"ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35\" targetRef=\"ibo-b52d8a37-0d31-4b20-ac94-7738386e91a1\">\n      <bpmn:extensionElements>\n        <xppm:Property name=\"link\" />\n      </bpmn:extensionElements>\n    </bpmn:sequenceFlow>\n    <bpmn:sequenceFlow id=\"ibo-c4633114-157e-4bd1-a90b-bdcd4ebfefa3\" sourceRef=\"ibo-a15b3687-0da5-49c6-915a-ff356b4db563\" targetRef=\"ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35\" />\n    <bpmn:sequenceFlow id=\"ibo-e4ea4018-b985-445c-b73b-769c7dcca934\" name=\"Ja\" sourceRef=\"ibo-0a4e2d95-452c-41b8-a824-6861de7c1599\" targetRef=\"ibo-a15b3687-0da5-49c6-915a-ff356b4db563\">\n      <bpmn:extensionElements>\n        <xppm:Property name=\"link\" />\n      </bpmn:extensionElements>\n    </bpmn:sequenceFlow>\n    <bpmn:sequenceFlow id=\"ibo-c85344b6-e4bc-49bb-85f3-c686beda58ba\" name=\"Nein\" sourceRef=\"ibo-0a4e2d95-452c-41b8-a824-6861de7c1599\" targetRef=\"ibo-b52d8a37-0d31-4b20-ac94-7738386e91a1\">\n      <bpmn:extensionElements>\n        <xppm:Property name=\"link\" />\n      </bpmn:extensionElements>\n    </bpmn:sequenceFlow>\n    <bpmn:sequenceFlow id=\"ibo-4f232862-c1b5-419c-9ba6-8bcc9b268d08\" sourceRef=\"ibo-3d6ad8ae-071a-412d-b83c-8c8fbe949c4b\" targetRef=\"ibo-0a4e2d95-452c-41b8-a824-6861de7c1599\" />\n    <bpmn:sequenceFlow id=\"ibo-af428b73-6d5c-4d62-812e-5b90d647c949\" sourceRef=\"ibo-5e06f3c2-eaf5-44d1-bf59-2ef8b72f1d48\" targetRef=\"ibo-3d6ad8ae-071a-412d-b83c-8c8fbe949c4b\" />\n    <bpmn:dataObjectReference id=\"ibo-153351dc-9bae-4c85-9b51-eeb411c5b9b6\" name=\"Rückmeldung KI\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_8b6d61ba-21bd-4e9a-ab90-61e0ae87166d\">Rückmeldung zur Beauftragung vom Kantonsingenieur</bpmn:documentation>\n    </bpmn:dataObjectReference>\n    <bpmn:sequenceFlow id=\"ibo-a5a1cbdc-4cbf-4cd1-afeb-58310f55ed0b\" name=\"Ja\" sourceRef=\"ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35\" targetRef=\"ibo-8e7f6b3a-7a0f-4ffa-b594-ef722aaad87c\">\n      <bpmn:extensionElements>\n        <xppm:Property name=\"link\" />\n      </bpmn:extensionElements>\n    </bpmn:sequenceFlow>\n    <bpmn:dataObjectReference id=\"ibo-e715b79c-f6c5-4c92-988a-01401ea4ba20\" name=\"Nachtragsmeldung GPL TBA\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_66861f9a-1e84-4da6-a4e3-3e4fd835e7ff\">Vom GPL ergänzte Nachtragsmeldung</bpmn:documentation>\n    </bpmn:dataObjectReference>\n    <bpmn:task id=\"ibo-8e7f6b3a-7a0f-4ffa-b594-ef722aaad87c\" name=\"Nachtrag beauftragen\" startQuantity=\"0\" completionQuantity=\"0\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_2afa2a1f-5431-4976-8a82-26b78b5883e9\">Der GPL formuliert die Beauftragung an den Unternehmer.</bpmn:documentation>\n      <bpmn:incoming>ibo-8e7f6b3a-7a0f-4ffa-b594-ef722aaad87c</bpmn:incoming>\n      <bpmn:outgoing>ibo-8e7f6b3a-7a0f-4ffa-b594-ef722aaad87c</bpmn:outgoing>\n      <bpmn:dataInputAssociation id=\"ibo-721e5c5a-8513-4456-8676-63be6b357832\">\n        <bpmn:sourceRef>ibo-153351dc-9bae-4c85-9b51-eeb411c5b9b6</bpmn:sourceRef>\n      </bpmn:dataInputAssociation>\n      <bpmn:dataOutputAssociation id=\"ibo-47aabde8-d964-40a4-96ea-907f53abfa37\">\n        <bpmn:targetRef>ibo-939300a9-1a9f-4d96-8739-191b49ef5aa9</bpmn:targetRef>\n      </bpmn:dataOutputAssociation>\n    </bpmn:task>\n    <bpmn:exclusiveGateway id=\"ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35\" gatewayDirection=\"Diverging\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_d5c7c5e6-8758-44cd-8ecd-799af724d6c5\">Wird der Nachtrag freigegeben?</bpmn:documentation>\n      <bpmn:incoming>ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35</bpmn:incoming>\n      <bpmn:outgoing>ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35</bpmn:outgoing>\n      <bpmn:outgoing>ibo-3de625f4-1fcc-4d0b-bb03-891869b20a35</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n    <bpmn:task id=\"ibo-a15b3687-0da5-49c6-915a-ff356b4db563\" name=\"Nachtrag prüfen\" startQuantity=\"0\" completionQuantity=\"0\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_f311279a-7bc0-41b6-a082-432e5a83f4f8\">Die vom GPL angereicherte Information wird vom Kantonsingenieur geprüft.</bpmn:documentation>\n      <bpmn:incoming>ibo-a15b3687-0da5-49c6-915a-ff356b4db563</bpmn:incoming>\n      <bpmn:outgoing>ibo-a15b3687-0da5-49c6-915a-ff356b4db563</bpmn:outgoing>\n      <bpmn:dataInputAssociation id=\"ibo-82cdee12-f5ac-447b-a2a8-6ddd7f7adce4\">\n        <bpmn:sourceRef>ibo-e715b79c-f6c5-4c92-988a-01401ea4ba20</bpmn:sourceRef>\n      </bpmn:dataInputAssociation>\n      <bpmn:dataOutputAssociation id=\"ibo-273ca4bb-308d-420d-ba4a-3fe9eff19029\">\n        <bpmn:targetRef>ibo-153351dc-9bae-4c85-9b51-eeb411c5b9b6</bpmn:targetRef>\n      </bpmn:dataOutputAssociation>\n    </bpmn:task>\n    <bpmn:task id=\"ibo-b52d8a37-0d31-4b20-ac94-7738386e91a1\" name=\"Begründung formulieren\" startQuantity=\"0\" completionQuantity=\"0\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_c4c09200-7129-46f7-a3a2-bd275fb0af24\">Der GPL formuliert die Begründung für die Ablehnung.</bpmn:documentation>\n      <bpmn:incoming>ibo-b52d8a37-0d31-4b20-ac94-7738386e91a1</bpmn:incoming>\n      <bpmn:incoming>ibo-b52d8a37-0d31-4b20-ac94-7738386e91a1</bpmn:incoming>\n      <bpmn:dataOutputAssociation id=\"ibo-75402b95-821f-4070-b066-9f8f1479309f\">\n        <bpmn:targetRef>ibo-3fff4c88-565c-4e5b-bde0-9f6631ea451a</bpmn:targetRef>\n      </bpmn:dataOutputAssociation>\n    </bpmn:task>\n    <bpmn:exclusiveGateway id=\"ibo-0a4e2d95-452c-41b8-a824-6861de7c1599\" gatewayDirection=\"Diverging\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_6b3ee045-8b51-40e9-8d63-ad0a20001935\">Wird der Nachtrag weitergeleitet?</bpmn:documentation>\n      <bpmn:incoming>ibo-0a4e2d95-452c-41b8-a824-6861de7c1599</bpmn:incoming>\n      <bpmn:outgoing>ibo-0a4e2d95-452c-41b8-a824-6861de7c1599</bpmn:outgoing>\n      <bpmn:outgoing>ibo-0a4e2d95-452c-41b8-a824-6861de7c1599</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n    <bpmn:task id=\"ibo-3d6ad8ae-071a-412d-b83c-8c8fbe949c4b\" name=\"Nachtrag prüfen\" startQuantity=\"0\" completionQuantity=\"0\">\n      <bpmn:documentation id=\"Bpmn_Documentation_Bem_a9248df4-25b5-42b2-bc35-c31dfbe48251\">Die Informationen des Unternehmers werden vom GPL geprüft (Plausibilität/Berechtigung/Grössenrelation zur Leistung) und entweder dem KI empfohlen zur Freigabe, oder dem an den Unternehmerzurückgewiesen. </bpmn:documentation>\n      <bpmn:incoming>ibo-3d6ad8ae-071a-412d-b83c-8c8fbe949c4b</bpmn:incoming>\n      <bpmn:outgoing>ibo-3d6ad8ae-071a-412d-b8