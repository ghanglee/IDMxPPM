              "definitionFigures": [],
              "examples": "",
              "exampleImages": [],
              "correspondingExternalElements": [],
              "subInformationUnits": []
            },
            {
              "id": "996db0f9-cae6-4f94-a40a-e67fbf76a873",
              "name": "Datum Grundvertrag",
              "dataType": "String",
              "isMandatory": true,
              "definition": "Offizielles Datum der Bauftragung (Vertragsdatum).",
              "definitionFigures": [],
              "examples": "11.03.2024",
